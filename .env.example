# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/helpdesk

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_TITLE=IT Helpdesk API
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SSO / OIDC
# URL of the frontend app — used to build the post-login redirect URL after SSO callback
FRONTEND_URL=http://localhost:5173

# Attachment object storage
# Options: "local" (dev) | "azure" | "s3"
ATTACHMENT_STORAGE_BACKEND=local

# Azure Blob Storage (used when ATTACHMENT_STORAGE_BACKEND=azure)
# AZURE_STORAGE_ACCOUNT_NAME=mystorageaccount
# AZURE_STORAGE_ACCOUNT_KEY=your-key-here
# AZURE_STORAGE_CONTAINER=attachments

# AWS S3 (used when ATTACHMENT_STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=my-attachments-bucket
# S3_ENDPOINT_URL=                      # leave blank for real AWS, set for MinIO/R2

# Local dev storage directory
LOCAL_ATTACHMENT_DIR=/tmp/attachments
